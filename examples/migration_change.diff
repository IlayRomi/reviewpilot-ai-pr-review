+++ b/db/migrations/0014_alter_user_permissions.sql
@@ -0,0 +1,22 @@
+-- Migration 0014: Restructure user permission model
+-- WARNING: This migration includes destructive operations.
+
+BEGIN;
+
+-- Drop the legacy role_assignments table (replaced by user_permissions)
+DROP TABLE IF EXISTS legacy_role_assignments;
+
+-- Remove obsolete columns from the users table
+ALTER TABLE users
+    DROP COLUMN IF EXISTS legacy_role,
+    DROP COLUMN IF EXISTS permissions_bitmap;
+
+-- Truncate the permission cache to force a rebuild
+TRUNCATE TABLE permission_cache;
+
+-- Add the new permission columns
+ALTER TABLE users
+    ADD COLUMN permission_level INTEGER NOT NULL DEFAULT 0,
+    ADD COLUMN permissions JSONB;
+
+COMMIT;
