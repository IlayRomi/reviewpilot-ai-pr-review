@@ -0,0 +1,19 @@
+"""Tests for pricing.calculate_discount."""
+
+from src.pricing import calculate_discount
+
+
+def test_standard_tier_no_discount():
+    assert calculate_discount(100.0, "standard") == 100.0
+
+
+def test_premium_tier_discount():
+    assert calculate_discount(100.0, "premium") == 80.0
+
+
+def test_enterprise_tier_discount():
+    assert calculate_discount(100.0, "enterprise") == 65.0
+
+
+def test_unknown_tier_no_discount():
+    assert calculate_discount(100.0, "unknown") == 100.0
