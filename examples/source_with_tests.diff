diff --git a/src/pricing.py b/src/pricing.py
index a1b2c3d..e4f5g6h 100644
--- a/src/pricing.py
+++ b/src/pricing.py
@@ -1,8 +1,10 @@
 """Pricing calculation utilities."""


-def calculate_discount(base_price: float, tier: str) -> float:
-    """Return the discounted price for the given tier."""
-    if tier == "premium":
-        return base_price * 0.8
-    return base_price
+DISCOUNT_RATES = {"standard": 1.0, "premium": 0.8, "enterprise": 0.65}
+
+
+def calculate_discount(base_price: float, tier: str) -> float:
+    """Return the discounted price for the given customer tier."""
+    rate = DISCOUNT_RATES.get(tier, 1.0)
+    return round(base_price * rate, 2)
